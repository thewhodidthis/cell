{
  "name": "@thewhodidthis/cell",
  "version": "0.0.0",
  "private": true,
  "description": "Paint worklet for producing grid based patterns",
  "keywords": [
    "houdini",
    "css",
    "grid"
  ],
  "homepage": "https://github.com/thewhodidthis/cell#readme",
  "bugs": {
    "url": "https://github.com/thewhodidthis/cell/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thewhodidthis/cell.git"
  },
  "license": "ISC",
  "author": "Sotiri Bakagiannis <sotirios.bakagiannis@gmail.com> (http://thewhodidthis.com)",
  "main": "index",
  "module": "index.mjs",
  "directories": {
    "example": "example"
  },
  "scripts": {
    "preexample": "eslint example/index.js",
    "example": "rollup -c node:x -f iife -n cell -o example/cell.js index.mjs",
    "prestart": "npm test",
    "start": "rollup -c node:x -f cjs -o index.js index.mjs",
    "test": "eslint index.mjs"
  },
  "eslintConfig": {
    "extends": "@thewhodidthis",
    "globals": {
      "registerPaint": true
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@thewhodidthis/arithmetics": "^0.0.5",
    "@thewhodidthis/eslint-config": "^0.0.17",
    "eslint": "^6.8.0",
    "poltocar": "^2.0.5",
    "rollup": "^1.31.1",
    "rollup-config-x": "^1.0.4"
  },
  "engines": {
    "node": ">=6.11.0",
    "npm": ">=3.10.10"
  }
}
